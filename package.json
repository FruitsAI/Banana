{
  "name": "banana",
  "version": "0.1.1",
  "description": "Banana is a local-first desktop AI assistant built with Next.js, Tauri, and SQLite.",
  "author": "FruitsAI",
  "license": "UNLICENSED",
  "homepage": "https://github.com/FruitsAI/Banana",
  "repository": {
    "type": "git",
    "url": "https://github.com/FruitsAI/Banana.git"
  },
  "bugs": {
    "url": "https://github.com/FruitsAI/Banana/issues"
  },
  "packageManager": "pnpm@10.30.3",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "changelog:check": "node scripts/changelog-manager.mjs check",
    "version:check": "node scripts/version-manager.mjs check",
    "version:sync": "node scripts/version-manager.mjs sync",
    "version:set": "node scripts/version-manager.mjs set",
    "version:patch": "node scripts/version-manager.mjs bump patch",
    "version:minor": "node scripts/version-manager.mjs bump minor",
    "version:major": "node scripts/version-manager.mjs bump major",
    "release:prepare": "node scripts/release-prepare.mjs",
    "release:prepare:minor": "node scripts/release-prepare.mjs minor",
    "release:prepare:major": "node scripts/release-prepare.mjs major",
    "release:tag:print": "node scripts/release-tag.mjs --print",
    "release:tag": "node scripts/release-tag.mjs",
    "release:tag:push": "node scripts/release-tag.mjs --push",
    "check:rust": "cargo check --manifest-path src-tauri/Cargo.toml && cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets -- -D warnings",
    "check:repo": "pnpm changelog:check && pnpm version:check && pnpm lint && pnpm test && pnpm build && pnpm check:rust",
    "desktop:build": "tauri build",
    "desktop:build:debug": "tauri build --debug --bundles app",
    "tauri": "tauri"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "3.0.63",
    "@ai-sdk/openai": "^3.0.37",
    "@hugeicons/core-free-icons": "^4.0.0",
    "@hugeicons/react": "^1.1.5",
    "@lobehub/icons": "^5.0.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "@tauri-apps/plugin-sql": "^2.3.2",
    "ai": "^6.0.105",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.35.1",
    "katex": "^0.16.38",
    "lucide-react": "^0.577.0",
    "mermaid": "^11.13.0",
    "next": "16.2.1",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "shiki": "^3.23.0",
    "tailwind-merge": "^3.5.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@tauri-apps/cli": "^2.10.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^11.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "fast-check": "^4.6.0",
    "jsdom": "^28.1.0",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.1.0"
  }
}
